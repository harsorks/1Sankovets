<Window x:Class="TTTLab1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Крестики-нолики v2" Height="700" Width="550"
        WindowStartupLocation="CenterScreen"
        Background="#FFE5E5E5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Настройки символов -->
        <GroupBox Grid.Row="0" Header="Настройка символов" 
                  Margin="20,20,20,10" 
                  Padding="10"
                  FontSize="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="5">
                    <TextBlock Text="Символ игрока 1 (X):" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtSymbolX" Text="X" 
                            FontSize="20" Height="35"
                            HorizontalContentAlignment="Center"
                            MaxLength="1"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="5">
                    <TextBlock Text="Символ игрока 2 (O):" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtSymbolO" Text="O" 
                            FontSize="20" Height="35"
                            HorizontalContentAlignment="Center"
                            MaxLength="1"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Счетчик побед -->
        <Border Grid.Row="1" Background="#FF4CAF50" 
                CornerRadius="10" Margin="20,10" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtWinsX" Text="0" 
                              FontSize="24" FontWeight="Bold"
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Побед X" 
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtDraws" Text="0" 
                              FontSize="24" FontWeight="Bold"
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Ничьи" 
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtWinsO" Text="0" 
                              FontSize="24" FontWeight="Bold"
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Побед O" 
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Игровое поле -->
        <UniformGrid Grid.Row="2" Rows="3" Columns="3" 
                     HorizontalAlignment="Center" 
                     VerticalAlignment="Center"
                     Margin="20"
                     Width="330" Height="330">
            <Button x:Name="btn0" Click="Button_Click" 
                    Content="" FontSize="36" FontWeight="Bold"
                    Margin="5" Background="White"
                    BorderBrush="#FF4A4A4A" BorderThickness="2"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
            <Button x:Name="btn1" Click="Button_Click" 
                    Content="" FontSize="36" FontWeight="Bold"
                    Margin="5" Background="White"
                    BorderBrush="#FF4A4A4A" BorderThickness="2"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
            <Button x:Name="btn2" Click="Button_Click" 
                    Content="" FontSize="36" FontWeight="Bold"
                    Margin="5" Background="White"
                    BorderBrush="#FF4A4A4A" BorderThickness="2"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
            <Button x:Name="btn3" Click="Button_Click" 
                    Content="" FontSize="36" FontWeight="Bold"
                    Margin="5" Background="White"
                    BorderBrush="#FF4A4A4A" BorderThickness="2"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
            <Button x:Name="btn4" Click="Button_Click" 
                    Content="" FontSize="36" FontWeight="Bold"
                    Margin="5" Background="White"
                    BorderBrush="#FF4A4A4A" BorderThickness="2"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
            <Button x:Name="btn5" Click="Button_Click" 
                    Content="" FontSize="36" FontWeight="Bold"
                    Margin="5" Background="White"
                    BorderBrush="#FF4A4A4A" BorderThickness="2"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
            <Button x:Name="btn6" Click="Button_Click" 
                    Content="" FontSize="36" FontWeight="Bold"
                    Margin="5" Background="White"
                    BorderBrush="#FF4A4A4A" BorderThickness="2"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
            <Button x:Name="btn7" Click="Button_Click" 
                    Content="" FontSize="36" FontWeight="Bold"
                    Margin="5" Background="White"
                    BorderBrush="#FF4A4A4A" BorderThickness="2"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
            <Button x:Name="btn8" Click="Button_Click" 
                    Content="" FontSize="36" FontWeight="Bold"
                    Margin="5" Background="White"
                    BorderBrush="#FF4A4A4A" BorderThickness="2"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
        </UniformGrid>

        <!-- Информация и кнопки -->
        <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock x:Name="txtInfo" Text="Нажмите 'Новая игра' для начала" 
                      FontSize="18" 
                      HorizontalAlignment="Center" 
                      Margin="0,0,0,15"
                      Foreground="#FF333333"
                      TextWrapping="Wrap"
                      TextAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Новая игра" Click="NewGame_Click" 
                       Width="150" Height="45" 
                       FontSize="16" Margin="5"
                       Background="#FF4CAF50" 
                       Foreground="White"
                       BorderThickness="0"
                       Cursor="Hand"/>
                <Button Content="Сбросить счет" Click="ResetScore_Click" 
                       Width="150" Height="45" 
                       FontSize="16" Margin="5"
                       Background="#FF2196F3" 
                       Foreground="White"
                       BorderThickness="0"
                       Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
